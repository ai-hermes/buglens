BUGLENS_SYSTEM_PROMPT=You are buglens, a focused sub-agent integrated through OpenClaw.
BUGLENS_RUNNER=langgraph
BUGLENS_LLM_PROVIDER=litellm
BUGLENS_ENABLE_MCP_TOOLS=true
BUGLENS_MCP_TOOL_CALL_MAX_STEPS=6
BUGLENS_SHOW_TOOL_CALL_TRACE=false
BUGLENS_MAX_TURNS=6
BUGLENS_TIMEOUT_SECONDS=180
BUGLENS_FIRST_PACKET_TIMEOUT_SECONDS=30
BUGLENS_PERMISSION_MODE=bypassPermissions
BUGLENS_ALLOWED_TOOLS=["Read","Write","Edit","Bash"]
# External MCP servers for langgraph runner (URL mode only)
# BUGLENS_MCP_SERVERS={"alibaba_cloud_observability":{"url":"http://localhost:8080"}}
# BUGLENS_ANTHROPIC_AUTH_TOKEN=
# BUGLENS_ANTHROPIC_API_KEY=
# BUGLENS_ANTHROPIC_BASE_URL=
# BUGLENS_ANTHROPIC_MODEL=
# BUGLENS_MODEL=deepseek-v3.2
# Optional for local testing without real model calls:
# BUGLENS_MOCK_RESPONSE=mocked response from buglens

# Alibaba Cloud ARMS/SLS (used by LangGraph built-in monitoring tools)
# Prefer RAM minimal permissions and temporary STS token.
# BUGLENS_ALIBABA_ACCESS_KEY_ID=
# BUGLENS_ALIBABA_ACCESS_KEY_SECRET=
# BUGLENS_ALIBABA_SECURITY_TOKEN=
# BUGLENS_ALIBABA_REGION_ID=cn-hangzhou
# Optional override endpoint:
# BUGLENS_ARMS_ENDPOINT=arms.aliyuncs.com
# BUGLENS_SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com
# Optional defaults for ARMS frontend (RUM) SLS-backed tools:
# BUGLENS_RUM_SLS_PROJECT=
# BUGLENS_RUM_SLS_LOGSTORE=
# Retry/rate-control tuning for monitoring calls:
# BUGLENS_MONITORING_MAX_RETRIES=2
# BUGLENS_MONITORING_BASE_BACKOFF_SECONDS=0.25
# BUGLENS_MONITORING_MAX_BACKOFF_SECONDS=5.0
# BUGLENS_MONITORING_MAX_CONCURRENCY=4

# GitLab environment for built-in MCP tools
GITLAB_URL=
GITLAB_TOKEN=
# Optional default project. If omitted, pass `project_id` in MCP tool calls.
# GITLAB_PROJECT_ID=
